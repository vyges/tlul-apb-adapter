  "interfaces": [
    {
      "type": "bus",
      "direction": "input",
      "protocol": "TL-UL",
      "width": 32,
      "description": "TileLink Uncached Lightweight (TL-UL) slave port — connects to TL-UL crossbar device port",
      "signals": [
        { "name": "clk_i",         "direction": "input",  "type": "clock",   "width": 1,  "description": "System clock" },
        { "name": "rst_ni",        "direction": "input",  "type": "reset",   "active_level": "low", "width": 1, "description": "Active-low synchronous reset" },
        { "name": "tl_a_valid_i",  "direction": "input",  "type": "control", "width": 1,  "description": "A channel valid" },
        { "name": "tl_a_opcode_i", "direction": "input",  "type": "control", "width": 3,  "description": "A channel opcode: 4=Get, 0=PutFullData, 1=PutPartialData" },
        { "name": "tl_a_param_i",  "direction": "input",  "type": "control", "width": 3,  "description": "A channel param (must be 0 for TL-UL)" },
        { "name": "tl_a_size_i",   "direction": "input",  "type": "control", "width": 2,  "description": "Transfer size log2: 0=1B, 1=2B, 2=4B" },
        { "name": "tl_a_source_i", "direction": "input",  "type": "data",    "width": 8,  "description": "Transaction ID (parameterizable SOURCE_WIDTH)" },
        { "name": "tl_a_address_i","direction": "input",  "type": "data",    "width": 32, "description": "Target address" },
        { "name": "tl_a_mask_i",   "direction": "input",  "type": "data",    "width": 4,  "description": "Byte enable mask (mapped to APB PSTRB when APB4_EN=1)" },
        { "name": "tl_a_data_i",   "direction": "input",  "type": "data",    "width": 32, "description": "Write data" },
        { "name": "tl_a_ready_o",  "direction": "output", "type": "control", "width": 1,  "description": "Adapter ready to accept new A channel request" },
        { "name": "tl_d_valid_o",  "direction": "output", "type": "control", "width": 1,  "description": "D channel valid" },
        { "name": "tl_d_opcode_o", "direction": "output", "type": "control", "width": 3,  "description": "D channel opcode: 0=AccessAck, 1=AccessAckData" },
        { "name": "tl_d_param_o",  "direction": "output", "type": "control", "width": 2,  "description": "D channel param (always 0)" },
        { "name": "tl_d_size_o",   "direction": "output", "type": "control", "width": 2,  "description": "Echo of a_size" },
        { "name": "tl_d_source_o", "direction": "output", "type": "data",    "width": 8,  "description": "Echo of a_source (transaction ID)" },
        { "name": "tl_d_error_o",  "direction": "output", "type": "control", "width": 1,  "description": "Error flag (PSLVERR passthrough when APB4_EN=1)" },
        { "name": "tl_d_data_o",   "direction": "output", "type": "data",    "width": 32, "description": "Read data (0 for write responses)" },
        { "name": "tl_d_ready_i",  "direction": "input",  "type": "control", "width": 1,  "description": "Host ready to accept D channel response" }
      ]
    },
    {
      "type": "bus",
      "direction": "output",
      "protocol": "APB",
      "width": 32,
      "description": "AMBA APB3/APB4 master port — connects to APB peripheral",
      "signals": [
        { "name": "apb_psel_o",    "direction": "output", "type": "control", "width": 1,  "description": "Peripheral select" },
        { "name": "apb_penable_o", "direction": "output", "type": "control", "width": 1,  "description": "Enable (access phase)" },
        { "name": "apb_pwrite_o",  "direction": "output", "type": "control", "width": 1,  "description": "Write enable (1=write, 0=read)" },
        { "name": "apb_paddr_o",   "direction": "output", "type": "data",    "width": 32, "description": "Address bus" },
        { "name": "apb_pwdata_o",  "direction": "output", "type": "data",    "width": 32, "description": "Write data" },
        { "name": "apb_pstrb_o",   "direction": "output", "type": "data",    "width": 4,  "description": "Write strobes (APB4: from tl_a_mask; APB3: all 1s)" },
        { "name": "apb_pprot_o",   "direction": "output", "type": "control", "width": 3,  "description": "Protection (APB4: always 3'b000)" },
        { "name": "apb_prdata_i",  "direction": "input",  "type": "data",    "width": 32, "description": "Read data from peripheral" },
        { "name": "apb_pready_i",  "direction": "input",  "type": "control", "width": 1,  "description": "Peripheral ready (extends access phase when low)" },
        { "name": "apb_pslverr_i", "direction": "input",  "type": "control", "width": 1,  "description": "Slave error (APB4; tie 0 for APB3 peripherals)" }
      ]
    }
  ],
  "parameters": [
    {
      "name": "AW",
      "type": "int",
      "default": 32,
      "description": "Address bus width in bits. Must be <= 32.",
      "range": { "min": 8, "max": 32 },
      "units": "bits",
      "required": false
    },
    {
      "name": "DW",
      "type": "int",
      "default": 32,
      "description": "Data bus width in bits. Must be 32 for TL-UL and standard APB.",
      "range": { "min": 32, "max": 32 },
      "units": "bits",
      "required": false
    },
    {
      "name": "SOURCE_WIDTH",
      "type": "int",
      "default": 8,
      "description": "TL-UL source/sink ID field width. Echo'd in d_source for crossbar routing.",
      "range": { "min": 1, "max": 16 },
      "units": "bits",
      "required": false
    },
    {
      "name": "APB4_EN",
      "type": "bit",
      "default": 1,
      "description": "APB version: 1=APB4 (PSTRB/PPROT/PSLVERR enabled), 0=APB3 (PSTRB=4'hF, PSLVERR ignored).",
      "range": { "min": 0, "max": 1 },
      "units": "boolean",
      "required": false
    }
  ],
